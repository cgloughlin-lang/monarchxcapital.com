footer .footer-links { margin: 12px 0; }
footer .footer-links a {
  color: var(--text-muted);
  text-decoration: none;
  font-size: 13px;
  letter-spacing: 0.1em;
  transition: color 0.3s;
}
footer .footer-links a:hover { color: var(--gold); }
</style>
