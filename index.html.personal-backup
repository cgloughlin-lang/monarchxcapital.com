<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg-primary: #1a1a2e;
  --bg-alt: #16162b;
  --bg-card: #1e1e36;
  --gold: #C9A962;
  --gold-dim: rgba(201,169,98,0.15);
  --text-heading: #F5F0E8;
  --text-body: #9a9ab0;
  --text-muted: #7a7a94;
  --text-dark: #555570;
  --border: #2d2d4a;
  --border-light: #363658;
}

::selection { background: var(--gold); color: var(--bg-primary); }

html { scroll-behavior: smooth; }

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg-primary);
  color: var(--text-body);
  font-weight: 300;
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
}

/* Scrollbar */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg-primary); }
::-webkit-scrollbar-thumb { background: var(--text-dark); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--gold); }

/* Layout */
.container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

/* Section spacing */
section { padding: 100px 0; }
@media (max-width: 768px) { section { padding: 70px 0; } }

/* Section label */
.section-label {
  color: var(--gold);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin-bottom: 16px;
}

/* Gold accent line */
.gold-line { width: 64px; height: 1px; background: var(--gold); margin-bottom: 32px; }

/* Headings */
h1, h2, h3 { color: var(--text-heading); font-weight: 300; }
h2 { font-size: clamp(28px, 4vw, 40px); letter-spacing: 0.12em; margin-bottom: 24px; }
h3 { font-size: 18px; letter-spacing: 0.03em; margin-bottom: 8px; }

/* Scroll reveal */
.reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ===== HEADER NAV ===== */
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 20px 0;
  background: rgba(26,26,46,0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.site-header .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.site-header .logo-img { height: 28px; width: auto; }
.site-header nav { display: flex; gap: 32px; }
.site-header nav a {
  color: var(--text-muted);
  text-decoration: none;
  font-size: 13px;
  letter-spacing: 0.1em;
  font-weight: 400;
  transition: color 0.3s;
}
.site-header nav a:hover { color: var(--gold); }
@media (max-width: 768px) {
  .site-header nav { gap: 16px; }
  .site-header nav a { font-size: 12px; letter-spacing: 0.05em; }
  .site-header .logo-img { height: 22px; }
}

/* ===== HERO ===== */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
  padding-top: 80px;
  background: radial-gradient(ellipse at 50% 40%, rgba(201,169,98,0.05) 0%, transparent 65%),
              var(--bg-primary);
}

.hero-logo { height: 48px; width: auto; margin-bottom: 40px; opacity: 0.9; }
@media (max-width: 768px) { .hero-logo { height: 36px; } }

.hero h1 {
  font-size: clamp(28px, 5vw, 52px);
  font-weight: 300;
  letter-spacing: 0.08em;
  margin-bottom: 24px;
  line-height: 1.2;
  max-width: 800px;
}
.hero h1 .gold { color: var(--gold); }

.hero .subtitle {
  font-size: clamp(15px, 2vw, 19px);
  color: var(--text-muted);
  letter-spacing: 0.06em;
  font-weight: 300;
  max-width: 640px;
  line-height: 1.6;
  margin-bottom: 48px;
}

.hero .metrics {
  display: flex;
  gap: 48px;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 48px;
}
.hero .metric {
  text-align: center;
}
.hero .metric .number {
  font-size: clamp(28px, 4vw, 42px);
  color: var(--gold);
  font-weight: 300;
  letter-spacing: 0.02em;
  line-height: 1;
}
.hero .metric .label {
  font-size: 12px;
  color: var(--text-dark);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-top: 8px;
}
@media (max-width: 600px) {
  .hero .metrics { gap: 24px 32px; }
  .hero .metric .number { font-size: 28px; }
}

/* Scroll indicator */
.scroll-indicator {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.scroll-indicator span {
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--text-dark);
  text-transform: uppercase;
}
.scroll-indicator .line {
  width: 1px;
  height: 40px;
  background: var(--text-dark);
  position: relative;
  overflow: hidden;
}
.scroll-indicator .line::after {
  content: '';
  position: absolute;
  top: -100%;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--gold);
  animation: scrollDown 2s ease-in-out infinite;
}
@keyframes scrollDown {
  0% { top: -100%; }
  50% { top: 100%; }
  100% { top: 100%; }
}

/* ===== ABOUT ===== */
.about { background: var(--bg-alt); }
.about .lead {
  font-size: clamp(20px, 3vw, 28px);
  color: var(--text-heading);
  font-weight: 300;
  line-height: 1.5;
  margin-bottom: 32px;
}
.about .body-text { max-width: 720px; margin-bottom: 24px; line-height: 1.8; font-size: 16px; }
.about .quote {
  border-left: 2px solid var(--gold);
  padding-left: 24px;
  font-size: clamp(18px, 2.5vw, 24px);
  color: var(--text-heading);
  font-weight: 300;
  font-style: italic;
  margin: 40px 0;
}

/* ===== CARDS GRID ===== */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
  margin-top: 40px;
}

.card {
  border: 1px solid var(--border);
  background: linear-gradient(135deg, var(--bg-card), var(--bg-primary));
  padding: 32px 28px;
  transition: border-color 0.3s ease, transform 0.3s ease;
}
.card:hover { border-color: var(--gold); transform: translateY(-2px); }
.card .card-num { color: var(--gold); font-size: 12px; letter-spacing: 0.2em; margin-bottom: 12px; }
.card p { color: var(--text-muted); font-size: 14px; line-height: 1.6; margin-top: 8px; }

.card.highlighted { border-color: var(--gold); position: relative; }
.card.highlighted::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(201,169,98,0.04);
  pointer-events: none;
}

/* ===== CASE STUDIES ===== */
.cases { background: var(--bg-alt); }
.case-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 24px;
  margin-top: 40px;
}
.case-card {
  border: 1px solid var(--border);
  background: var(--bg-card);
  padding: 32px;
  transition: border-color 0.3s;
}
.case-card:hover { border-color: var(--border-light); }
.case-card .case-tag {
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--gold);
  text-transform: uppercase;
  margin-bottom: 16px;
}
.case-card h3 { font-size: 17px; margin-bottom: 12px; font-weight: 400; }
.case-card .case-result {
  font-size: 26px;
  color: var(--gold);
  font-weight: 300;
  margin: 16px 0 12px;
  letter-spacing: 0.02em;
}
.case-card p { font-size: 14px; line-height: 1.6; color: var(--text-muted); }

/* ===== INDUSTRIES ===== */
.industries-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 32px;
}
.industry-tag {
  padding: 10px 20px;
  border: 1px solid var(--border);
  font-size: 13px;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  transition: border-color 0.3s, color 0.3s;
}
.industry-tag:hover { border-color: var(--gold); color: var(--text-heading); }

/* ===== BUYERS ===== */
.buyers-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 20px;
  margin-top: 40px;
}
.buyer-card {
  padding: 28px 24px;
  border: 1px solid var(--border);
  background: var(--bg-card);
}
.buyer-card h3 { font-size: 15px; font-weight: 400; margin-bottom: 8px; }
.buyer-card p { font-size: 13px; color: var(--text-muted); line-height: 1.5; }

/* ===== PRINCIPLES ===== */
.principles { counter-reset: principle; margin-top: 40px; }
.principle {
  display: flex;
  gap: 24px;
  padding: 24px 0;
  border-bottom: 1px solid var(--border);
  counter-increment: principle;
  align-items: flex-start;
}
.principle::before {
  content: counter(principle, decimal-leading-zero);
  color: var(--gold);
  font-size: 14px;
  letter-spacing: 0.1em;
  flex-shrink: 0;
  width: 28px;
  padding-top: 2px;
}
.principle h3 { margin-bottom: 4px; font-size: 16px; font-weight: 400; }
.principle p { font-size: 14px; color: var(--text-muted); line-height: 1.5; }

/* ===== CONTACT ===== */
.contact { background: var(--bg-alt); text-align: center; }
.contact .intro-text {
  font-size: clamp(22px, 3vw, 32px);
  color: var(--text-heading);
  font-weight: 300;
  margin-bottom: 16px;
}
.contact .sub-text {
  font-size: 16px;
  color: var(--text-muted);
  margin-bottom: 40px;
  max-width: 500px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.6;
}
.contact-links { display: flex; flex-direction: column; align-items: center; gap: 16px; margin-bottom: 40px; }
.contact-links a {
